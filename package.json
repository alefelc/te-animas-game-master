{
  "name": "te-animas-adaptive-api",
  "version": "5.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:domain": "npm run build --workspace @te-animas/game-domain",
    "build:contracts": "npm run build:domain && npm run build --workspace @te-animas/contracts",
    "build": "npm run build:contracts && tsc -p tsconfig.json",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "openai": "6.48.0",
    "zod": "4.4.3",
    "@te-animas/contracts": "5.0.0",
    "@te-animas/game-domain": "5.0.0"
  },
  "devDependencies": {
    "@types/node": "24.10.13",
    "typescript": "6.0.3"
  }
}
